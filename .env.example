# fAInancial-agent 환경변수 예시
# 이 파일을 복사하여 .env를 생성하고 실제 값을 입력하세요.
# cp .env.example .env

# DART OpenAPI 키 (https://opendart.fss.or.kr)
DART_API_KEY=your-dart-api-key

# Voyage AI 임베딩 API 키 (https://dash.voyageai.com)
VOYAGE_API_KEY=your-voyage-api-key

# Google Gemini API 키 (https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key

# Gemini 모델 (기본값: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# === LangFuse Observability (선택) ===
# docker-compose.langfuse.yml 사용 시 필요

# ENCRYPTION_KEY (필수, 최초 1회 생성: openssl rand -hex 32)
ENCRYPTION_KEY=

# LangFuse 대시보드 API Keys (대시보드 Settings → API Keys에서 발급)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# MinIO Object Storage (기본값 변경 권장)
MINIO_ROOT_PASSWORD=
