# =============================================================================
# Claude Runtime — 런타임 생성 파일, 버전 관리 불필요
# =============================================================================
.claude/statsig/
.claude/todos/
.claude/audit.log
.claude/settings.local.json

# =============================================================================
# Secrets — 실제 값 파일 (구조 파악용 .env.example은 허용)
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*credentials*
*secrets*
terraform.tfvars

# =============================================================================
# OS / Editor
# =============================================================================
.DS_Store
.idea/
.vscode/
Thumbs.db

# =============================================================================
# Ecosystem — 아래 섹션에서 프로젝트에 맞는 항목 활성화
# =============================================================================

# --- Node.js ---
# node_modules/
# dist/
# .next/
# .nuxt/

# --- Python ---
__pycache__/
*.pyc
.venv/
dist/
*.egg-info/
.uv/

# --- Go ---
# vendor/
# *.test

# --- Rust ---
# target/

# --- Data (인덱스·다운로드 파일은 버전 관리 제외) ---
data/documents/*
data/faiss/*
data/eval/results_*.json
!data/**/.gitkeep

# =============================================================================
# SAGA / Process docs — 구현과 무관한 프로세스 문서
# =============================================================================
